---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { label: 'Instagram',   href: 'https://www.instagram.com/0uroborusss' },
  { label: 'Email',       href: 'mailto:ouroborusss@gmail.com' },
];
---

<BaseLayout title="About">
  <div class="wrap">
    <div class="about-layout">

      <section class="about-bio">
        <h1 class="about-heading">About</h1>
        <div class="bio-body">
          <p>
            I make ...things in Blender . sometimes landscapes, abstract forms, or stills.
            Each series is an experiment in feel, light, and creativity.
          </p>
          <p>
            This portfolio is an ongoing journal of that work.
          </p>
        </div>
      </section>

      <section class="about-contact" id="contact">
        <h2 class="contact-heading">Contact &amp; Links</h2>
        <ul class="social-list">
          {socials.map(s => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-link">
                <span class="social-label">{s.label}</span>
                <span class="social-arrow">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding: 8vh 0 80px;
    align-items: start;
  }
  @media (max-width: 700px) {
    .about-layout { grid-template-columns: 1fr; gap: 48px; }
  }

  .about-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    line-height: 0.9;
    margin-bottom: 32px;
  }

  .bio-body p {
    color: var(--muted);
    line-height: 1.75;
    max-width: 46ch;
    margin-bottom: 16px;
  }
  .bio-body p:last-child { margin-bottom: 0; }

  .contact-heading {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
    padding-top: 6px;
  }

  .social-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--edge);
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--fg);
    transition: color 0.2s, border-color 0.2s;
  }
  .social-list li:first-child .social-link { border-top: 1px solid var(--edge); }
  .social-link:hover { color: var(--accent); border-color: var(--accent-dk); }

  .social-arrow {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--muted);
    transition: color 0.2s, transform 0.2s;
  }
  .social-link:hover .social-arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }
</style>
