---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Ouroborusss',
  description = 'Blender renders — landscapes, abstract ideas, and stills.',
  ogImage,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // strip trailing slash — always use `${base}/path`
const pageTitle = title === 'Ouroborusss' ? title : `${title} — Ouroborusss`;
const ogImageUrl = new URL(`${base}/${ogImage ?? 'og-image.svg'}`, Astro.site ?? Astro.url).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

  <!-- OpenGraph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageUrl} />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageUrl} />
</head>
<body>
  <header class="site-nav">
    <div class="wrap">
      <a href={`${base}/`} class="nav-logo">Ouroborusss</a>
      <nav>
        <ul class="nav-links">
          <li><a href={`${base}/`} aria-current={Astro.url.pathname === `${base}/` ? 'page' : undefined}>Work</a></li>
          <li><a href={`${base}/about`} aria-current={Astro.url.pathname.startsWith(`${base}/about`) ? 'page' : undefined}>About</a></li>
          <li><a href={`${base}/about#contact`}>Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="wrap">
      <span>© {new Date().getFullYear()} Ouroborusss</span>
      <span>Rendered in Blender</span>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
